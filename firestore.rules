rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function claims() { return request.auth.token; }
    function isAuth() { return request.auth != null; }

    function isSuperUser() {
      return isAuth() && claims().role == 'superuser';
    }

    function isOwner(tenantId) {
      return isAuth()
          && claims().role == 'owner'
          && claims().tenant_id == tenantId;
    }

    function isStaff(tenantId, branchId) {
      return isAuth()
          && claims().role == 'staff'
          && claims().tenant_id == tenantId
          && claims().branch_id == branchId;
    }

    function belongsToTenant(tenantId) {
      return isAuth() && claims().tenant_id == tenantId;
    }

    function canManageBranch(tenantId, branchId) {
      return isSuperUser()
          || isOwner(tenantId)
          || isStaff(tenantId, branchId);
    }

    // ─── Users (staff, owners, superuser) ───────────────────────────────────

    match /users/{userId} {
      // Cada usuario lee y actualiza su propio perfil
      allow read: if isAuth() && request.auth.uid == userId;

      // Superuser gestiona todos los usuarios
      allow read, write: if isSuperUser();

      // Owner gestiona el staff de su propio tenant
      allow read: if isAuth()
          && claims().role == 'owner'
          && resource.data.tenant_id == claims().tenant_id;
      allow create: if isAuth()
          && claims().role == 'owner'
          && request.resource.data.tenant_id == claims().tenant_id;
      allow update: if isAuth()
          && claims().role == 'owner'
          && resource.data.tenant_id == claims().tenant_id;
    }

    // ─── Tenants ────────────────────────────────────────────────────────────

    match /tenants/{tenantId} {
      allow read:   if isSuperUser() || belongsToTenant(tenantId);
      allow create: if isSuperUser();
      allow update: if isSuperUser() || isOwner(tenantId);
      allow delete: if isSuperUser();

      // ─── Branches ───────────────────────────────────────────────────────

      match /branches/{branchId} {
        allow read:           if isSuperUser() || belongsToTenant(tenantId);
        allow create, update: if isSuperUser() || isOwner(tenantId);
        allow delete:         if isSuperUser() || isOwner(tenantId);

        // Check-ins: log inmutable — solo append para personal operativo
        match /check_ins/{checkInId} {
          allow read:           if canManageBranch(tenantId, branchId);
          allow create:         if isAuth() && belongsToTenant(tenantId);
          allow update, delete: if false;
        }
      }

      // ─── Members ────────────────────────────────────────────────────────

      match /members/{memberId} {
        allow read: if isSuperUser()
            || isOwner(tenantId)
            || (isAuth() && claims().tenant_id == tenantId && claims().branch_id in resource.data.allowed_branches)
            || (isAuth() && request.auth.uid == memberId);

        allow create: if isSuperUser()
            || isOwner(tenantId)
            || isStaff(tenantId, request.resource.data.allowed_branches[0]);

        allow update: if isSuperUser()
            || isOwner(tenantId)
            || isStaff(tenantId, resource.data.allowed_branches[0]);

        allow delete: if isSuperUser() || isOwner(tenantId);
      }

      // ─── Membership Plans ───────────────────────────────────────────────

      match /membership_plans/{planId} {
        allow read:  if isAuth() && belongsToTenant(tenantId);
        allow write: if isSuperUser() || isOwner(tenantId);
      }

      // ─── Payments ───────────────────────────────────────────────────────

      match /payments/{paymentId} {
        allow read: if isSuperUser()
            || isOwner(tenantId)
            || isStaff(tenantId, resource.data.branch_id)
            || (isAuth() && request.auth.uid == resource.data.member_id);

        allow create: if isAuth() && belongsToTenant(tenantId);
        allow update: if isSuperUser()
            || isOwner(tenantId)
            || isStaff(tenantId, resource.data.branch_id);
        allow delete: if isSuperUser();
      }
    }
  }
}
