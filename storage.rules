rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Logos de tenants — lectura pública, escritura solo del owner del tenant
    match /tenant_logos/{tenantId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
          && (request.auth.token.role == 'superuser'
              || (request.auth.token.role == 'owner'
                  && request.auth.token.tenant_id == tenantId));
    }

    // Fotos de perfil — lectura pública autenticada, escritura solo del propio usuario
    match /profile_photos/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
